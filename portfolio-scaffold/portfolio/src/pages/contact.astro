---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import GlassPanel from "../components/GlassPanel.astro";
import TerminalHeader from "../components/TerminalHeader.astro";
---

<Layout title="SRE_TERMINAL // CONTACT">
  <Navigation currentPage="/contact" />
  
  <div class="pt-24 pb-12 px-6 md:px-margin_desktop max-w-container_max_width mx-auto">
    <header class="mb-12 text-center md:text-left">
      <h1 class="font-display text-display text-primary-fixed mb-2">CONTACT_INFO</h1>
      <p class="font-code-sm text-code-sm text-on-surface-variant uppercase tracking-widest">DECRYPTING COMMUNICATIONS CHANNELS FOR SITHILA_KONARA.SRE</p>
    </header>
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Terminal Info Section -->
      <div class="lg:col-span-8">
        <GlassPanel class="rounded-lg overflow-hidden flex flex-col h-full relative">
          <div class="scanline"></div>
          <TerminalHeader label="sh: cat etc/contacts.yaml" />
          <div class="p-6 md:p-10 flex-grow font-code-sm">
            <div class="mb-8 text-secondary-fixed">
              <p class="mb-1">&gt; fetch --source remote_profile.yaml</p>
              <p class="mb-1 text-on-surface-variant">[ OK ] Record located in encrypted partition.</p>
              <p class="mb-4">&gt; cat etc/contacts.yaml</p>
            </div>
            <div class="space-y-6">
              <div class="grid grid-cols-[120px_1fr] gap-4">
                <span class="text-primary-fixed">EMAIL:</span>
                <span class="text-primary-fixed-dim">sithila@konara.sre</span>
              </div>
              <div class="grid grid-cols-[120px_1fr] gap-4">
                <span class="text-primary-fixed">PHONE:</span>
                <span class="text-primary-fixed-dim">+1 234 567 8910</span>
              </div>
              <div class="grid grid-cols-[120px_1fr] gap-4 items-start">
                <span class="text-primary-fixed">SOCIALS:</span>
                <div class="space-y-3">
                  <div class="flex items-center gap-4 group">
                    <span class="text-on-surface-variant w-24">GITHUB:</span>
                    <a class="text-primary-fixed-dim hover:text-primary hover:underline transition-colors" href="#">/SITHILA-K</a>
                  </div>
                  <div class="flex items-center gap-4 group">
                    <span class="text-on-surface-variant w-24">LINKEDIN:</span>
                    <a class="text-primary-fixed-dim hover:text-primary hover:underline transition-colors" href="#">/IN/SITHILAK</a>
                  </div>
                  <div class="flex items-center gap-4 group">
                    <span class="text-on-surface-variant w-24">MEDIUM:</span>
                    <a class="text-primary-fixed-dim hover:text-primary hover:underline transition-colors" href="#">@SITHILA_SRE</a>
                  </div>
                </div>
              </div>
              <div class="grid grid-cols-[120px_1fr] gap-4 pt-4 border-t border-outline-variant/30">
                <span class="text-primary-fixed">STATUS:</span>
                <div class="flex items-center gap-2 text-secondary-fixed">
                  <span class="w-2 h-2 rounded-full bg-secondary-container animate-pulse"></span>
                  <span>LISTENING_FOR_INCOMING_TRAFFIC</span>
                </div>
              </div>
            </div>
            <div class="mt-12 p-4 bg-surface-container-low border border-outline-variant/30 rounded">
              <p class="text-on-surface-variant leading-relaxed">
                <span class="text-secondary-fixed"># INFO:</span> 
                Encrypted handshake required for direct terminal access. Use the provided credentials to establish a secure connection via standard protocols.
              </p>
            </div>
          </div>
        </GlassPanel>
      </div>
      
      <!-- Sidebar Section -->
      <aside class="lg:col-span-4 flex flex-col gap-8">
        <!-- System Status Sidebar -->
        <GlassPanel class="rounded-lg p-6">
          <h3 class="font-label-caps text-label-caps text-primary-fixed mb-6 border-b border-outline-variant pb-2">SYSTEM_STATUS</h3>
          <div class="space-y-4 font-code-xs text-code-xs">
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">NODE_LATENCY:</span>
              <span class="text-secondary-fixed" id="latency-val">14ms</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">PUBLIC_IP:</span>
              <span class="text-primary-fixed-dim" id="sim-ip">192.168.0.1</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">TLS_HANDSHAKE:</span>
              <span class="text-secondary-fixed">SUCCESS</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">UPTIME:</span>
              <span class="text-on-surface" id="uptime">364:12:05:44</span>
            </div>
            <div class="mt-6 pt-4 border-t border-outline-variant">
              <div class="w-full h-1 bg-surface-container-high relative overflow-hidden">
                <div class="absolute top-0 left-0 h-full bg-primary-fixed w-1/3 animate-[progress_3s_ease-in-out_infinite]"></div>
              </div>
              <p class="mt-2 text-[10px] text-outline text-right">MONITORING_ACTIVE_NODES...</p>
            </div>
          </div>
        </GlassPanel>
        
        <!-- Social Nodes -->
        <GlassPanel class="rounded-lg p-6 flex-grow">
          <h3 class="font-label-caps text-label-caps text-primary-fixed mb-6 border-b border-outline-variant pb-2">SOCIAL_NODES</h3>
          <div class="flex flex-col gap-4">
            <a class="group flex items-center justify-between p-4 bg-surface-container-lowest/50 hover:bg-primary-fixed/10 transition-all border border-transparent hover:border-primary-fixed/40" href="#">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-fixed">code</span>
                <span class="font-code-sm text-code-sm group-hover:text-primary-fixed">GITHUB</span>
              </div>
              <span class="font-code-xs text-code-xs text-outline opacity-0 group-hover:opacity-100 transition-opacity">/SITHILA-K</span>
            </a>
            <a class="group flex items-center justify-between p-4 bg-surface-container-lowest/50 hover:bg-primary-fixed/10 transition-all border border-transparent hover:border-primary-fixed/40" href="#">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-fixed">hub</span>
                <span class="font-code-sm text-code-sm group-hover:text-primary-fixed">LINKEDIN</span>
              </div>
              <span class="font-code-xs text-code-xs text-outline opacity-0 group-hover:opacity-100 transition-opacity">/IN/SITHILAK</span>
            </a>
            <a class="group flex items-center justify-between p-4 bg-surface-container-lowest/50 hover:bg-primary-fixed/10 transition-all border border-transparent hover:border-primary-fixed/40" href="#">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-fixed">history_edu</span>
                <span class="font-code-sm text-code-sm group-hover:text-primary-fixed">MEDIUM</span>
              </div>
              <span class="font-code-xs text-code-xs text-outline opacity-0 group-hover:opacity-100 transition-opacity">@SITHILA_SRE</span>
            </a>
          </div>
        </GlassPanel>
      </aside>
    </div>
  </div>
  
  <Footer />
</Layout>

<style>
  @keyframes progress {
    0% { left: -100%; }
    100% { left: 100%; }
  }
  .pulse-status {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.9); }
  }
</style>