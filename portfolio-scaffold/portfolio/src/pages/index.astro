---
// src/pages/index.astro
import Base from '../layouts/Base.astro';

const techStack = [
  { id: 'NODE_01', label: 'Kubernetes' },
  { id: 'NODE_02', label: 'Terraform' },
  { id: 'NODE_03', label: 'Docker' },
  { id: 'NODE_04', label: 'AWS/GCP' },
  { id: 'NODE_05', label: 'Python' },
  { id: 'NODE_06', label: 'CI/CD' },
];

// Load latest 3 articles from posts.json (auto-generated by GH Actions)
let posts = [];
try {
  const raw = await import('../data/posts.json');
  posts = raw.default.slice(0, 3);
} catch {
  // posts.json doesn't exist yet — show placeholder cards
  posts = [];
}
---

<Base title="Home">

  <!-- ── Hero ── -->
  <section class="hero container">
    <div class="hero__left">
      <div class="status-badge" style="margin-bottom: var(--space-3)">
        <span class="dot"></span>
        SYSTEM STATUS: OPTIMAL
      </div>

      <h1 class="text-display hero__heading">
        Engineering <span class="text-cyan">Resilience</span><br />
        into the Cloud.
      </h1>

      <p class="text-body-lg hero__sub">
        Specializing in high-availability systems, automated infrastructure,
        and low-latency monitoring for complex cloud ecosystems.
      </p>

      <div class="hero__cta">
        <a href="/contact" class="btn btn-primary">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <rect x="0.5" y="0.5" width="13" height="13" rx="2" stroke="currentColor" stroke-width="1"/>
            <path d="M3 4.5l2.5 2.5L3 9.5M7.5 9.5h3.5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          ACCESS TERMINAL
        </a>
        <a href="/experience" class="btn btn-ghost">VIEW PROTOCOLS</a>
      </div>
    </div>

    <div class="hero__right">
      <div class="terminal-card hero__terminal">
        <div class="terminal-card__header">
          <div class="terminal-card__controls">
            <span class="terminal-card__dot terminal-card__dot--red"></span>
            <span class="terminal-card__dot terminal-card__dot--yellow"></span>
            <span class="terminal-card__dot terminal-card__dot--green"></span>
          </div>
          <span class="terminal-card__title">root@sre-profile: ~</span>
        </div>
        <div class="terminal-card__body terminal__output">
          <p class="terminal__line"><span class="terminal__chevron">›</span> Initializing SRE_Profile...</p>
          <p class="terminal__line"><span class="terminal__chevron">›</span> Cloud: AWS/GCP <span class="terminal__ok">[OK]</span></p>
          <p class="terminal__line"><span class="terminal__chevron">›</span> Infrastructure: Terraform/K8s <span class="terminal__ok">[OK]</span></p>
          <p class="terminal__line"><span class="terminal__chevron">›</span> Security: mTLS/RBAC <span class="terminal__ok">[OK]</span></p>
          <p class="terminal__line"><span class="terminal__chevron">›</span> Latency: 12ms <span class="terminal__stable">[STABLE]</span></p>
          <p class="terminal__status">Status: Seeking New Challenges<span class="terminal__cursor">_</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Tech Stack ── -->
  <section class="tech container">
    <div class="section-label">
      <span class="text-label">TECH_STACK // CORE_COMPETENCIES</span>
    </div>
    <div class="tech__grid">
      {techStack.map(item => (
        <div class="tech__node terminal-card">
          <div class="terminal-card__body">
            <span class="text-label tech__node-id">{item.id}</span>
            <p class="tech__node-label">{item.label}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Latest Articles ── -->
  <section class="articles container">
    <div class="section-label">
      <h2 class="text-headline">Latest from Medium</h2>
      <span class="text-label articles__meta">PUBLISHED_INSIGHTS.DAT</span>
      <a href="/articles" class="articles__read-all text-label">READ_ALL_POSTS →</a>
    </div>

    <div class="articles__grid">
      {posts.length > 0 ? posts.map((post: any) => (
        <a href={post.link} target="_blank" rel="noopener" class="article-card terminal-card">
          {post.thumbnail && (
            <img src={post.thumbnail} alt={post.title} class="article-card__img" loading="lazy" />
          )}
          <div class="terminal-card__body">
            <div class="article-card__meta">
              <span class="chip chip--cyan">{post.category ?? 'DEVOPS'}</span>
              <span class="text-label">{post.pubDate}</span>
            </div>
            <h3 class="article-card__title">{post.title}</h3>
            <p class="article-card__excerpt text-mono">{post.excerpt}</p>
          </div>
        </a>
      )) : (
        <!-- Placeholder cards shown before posts.json exists -->
        ['SECURITY', 'INFRA', 'AUTOMATION'].map(cat => (
          <div class="article-card terminal-card article-card--placeholder">
            <div class="article-card__img-placeholder"></div>
            <div class="terminal-card__body">
              <div class="article-card__meta">
                <span class="chip chip--cyan">{cat}</span>
              </div>
              <div class="article-card__title-placeholder"></div>
              <div class="article-card__excerpt-placeholder"></div>
            </div>
          </div>
        ))
      )}
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta">
    <div class="cta__inner terminal-card container">
      <h2 class="text-display">Ready to build resilient<br />systems?</h2>
      <p class="text-body-lg">
        Currently accepting requests for high-impact SRE and DevOps<br />
        consultancy. Connection window is open.
      </p>
      <a href="/contact" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="0.5" y="0.5" width="13" height="13" rx="2" stroke="currentColor" stroke-width="1"/>
          <path d="M3 4.5l2.5 2.5L3 9.5M7.5 9.5h3.5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        ACCESS TERMINAL
      </a>
    </div>
  </section>

</Base>

<style>
  /* ── Hero ── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  .hero__heading {
    margin: var(--space-3) 0;
  }

  .hero__sub {
    margin-bottom: var(--space-4);
    max-width: 46ch;
  }

  .hero__cta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* Terminal output */
  .terminal__output {
    font-family: var(--font-mono);
    font-size: var(--text-code-sm-size);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .terminal__line {
    color: var(--c-green);
    display: flex;
    gap: var(--space-1);
    align-items: baseline;
  }

  .terminal__chevron {
    color: var(--c-cyan);
    flex-shrink: 0;
  }

  .terminal__ok     { color: var(--c-green); }
  .terminal__stable { color: var(--c-cyan); }

  .terminal__status {
    color: var(--color-on-surface-variant);
    margin-top: var(--space-2);
  }

  .terminal__cursor {
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ── Tech Stack ── */
  .tech {
    padding-bottom: var(--space-8);
  }

  .tech__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-2);
  }

  .tech__node-id {
    display: block;
    font-size: 10px;
    margin-bottom: 6px;
    color: var(--color-outline);
  }

  .tech__node-label {
    font-family: var(--font-sans);
    font-size: var(--text-body-md-size);
    font-weight: 600;
    color: var(--color-on-surface);
  }

  /* ── Articles ── */
  .articles {
    padding-bottom: var(--space-8);
  }

  .articles__meta {
    margin-left: auto;
    font-size: 10px;
  }

  .articles__read-all {
    color: var(--c-cyan);
    text-decoration: none;
    font-size: var(--text-label-size);
    white-space: nowrap;
    transition: color var(--transition-fast);
  }

  .articles__read-all:hover {
    color: var(--color-primary);
  }

  .articles__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .article-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base);
  }

  .article-card:hover {
    transform: translateY(-4px);
  }

  .article-card__img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .article-card__img-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-surface-container-high);
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
    margin-top: var(--space-2);
  }

  .article-card__title {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-on-surface);
    margin-bottom: var(--space-1);
  }

  .article-card__excerpt {
    color: var(--color-on-surface-variant);
    font-size: var(--text-code-xs-size);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card__title-placeholder,
  .article-card__excerpt-placeholder {
    border-radius: var(--radius);
    background: var(--color-surface-container-high);
    animation: shimmer 1.5s ease-in-out infinite;
  }
  .article-card__title-placeholder   { height: 48px; margin-bottom: var(--space-1); }
  .article-card__excerpt-placeholder { height: 32px; }

  @keyframes shimmer {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 0.7; }
  }

  /* ── CTA ── */
  .cta {
    padding: 0 var(--space-8) var(--space-10);
  }

  .cta__inner {
    text-align: center;
    padding: var(--space-8) var(--space-4);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .cta__inner .text-body-lg {
    max-width: 52ch;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .tech__grid { grid-template-columns: repeat(3, 1fr); }
    .articles__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; }
    .hero__right { display: none; }
    .tech__grid { grid-template-columns: repeat(2, 1fr); }
    .articles__grid { grid-template-columns: 1fr; }
  }
</style>
