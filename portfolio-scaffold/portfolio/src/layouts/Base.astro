---
// src/layouts/Base.astro
// Wraps every page with <head>, nav, and footer shell

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'SRE & Cloud Engineering Portfolio' } = Astro.props;
const navLinks = [
  { href: '/',            label: 'Home' },
  { href: '/experience',  label: 'Experience' },
  { href: '/articles',    label: 'Articles' },
  { href: '/projects',    label: 'Projects' },
  { href: '/contact',     label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — SRE_CORE</title>
  <link rel="stylesheet" href="/styles/tokens.css" />
</head>
<body>

  <!-- ── Navbar ── -->
  <nav class="navbar">
    <div class="container navbar__inner">
      <a href="/" class="navbar__logo text-mono">SRE_CORE_v1.0</a>

      <ul class="navbar__links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['navbar__link', { 'navbar__link--active': currentPath === link.href }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <a href="/contact" class="navbar__terminal-icon" aria-label="Open terminal / contact">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <rect x="1" y="1" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.2"/>
          <path d="M5 7l3 3-3 3M10 13h5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </nav>

  <!-- ── Page Content ── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ── -->
  <footer class="footer">
    <div class="container footer__inner">
      <span class="text-mono footer__brand">SRE_CORE</span>
      <span class="text-mono footer__copy">© 2024 SYSTEM_ROOT. ALL RIGHTS RESERVED.</span>
      <nav class="footer__links">
        <a href="https://github.com" target="_blank" rel="noopener" class="footer__link">GitHub</a>
        <a href="https://linkedin.com" target="_blank" rel="noopener" class="footer__link">LinkedIn</a>
        <a href="https://medium.com" target="_blank" rel="noopener" class="footer__link">Medium</a>
      </nav>
    </div>
  </footer>

</body>
</html>

<style>
  /* ── Navbar ── */
  .navbar {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: rgba(13, 21, 21, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: var(--border-default);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    height: 56px;
    gap: var(--space-4);
  }

  .navbar__logo {
    color: var(--c-cyan);
    text-decoration: none;
    font-weight: var(--text-label-weight);
    letter-spacing: var(--text-label-ls);
    text-transform: uppercase;
    font-size: var(--text-label-size);
    white-space: nowrap;
  }

  .navbar__links {
    display: flex;
    list-style: none;
    gap: var(--space-4);
    margin-left: auto;
  }

  .navbar__link {
    font-family: var(--font-sans);
    font-size: var(--text-body-md-size);
    font-weight: 400;
    color: var(--color-on-surface-variant);
    text-decoration: none;
    padding-bottom: 2px;
    transition: color var(--transition-fast);
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--c-cyan);
    transform: scaleX(0);
    transition: transform var(--transition-fast);
  }

  .navbar__link:hover,
  .navbar__link--active {
    color: var(--color-on-surface);
  }

  .navbar__link--active::after,
  .navbar__link:hover::after {
    transform: scaleX(1);
  }

  .navbar__terminal-icon {
    color: var(--color-on-surface-variant);
    text-decoration: none;
    display: flex;
    align-items: center;
    margin-left: var(--space-2);
    transition: color var(--transition-fast);
  }

  .navbar__terminal-icon:hover {
    color: var(--c-cyan);
  }

  /* ── Footer ── */
  .footer {
    border-top: var(--border-default);
    padding: var(--space-3) 0;
    margin-top: var(--space-12);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__brand {
    color: var(--c-cyan);
    font-size: var(--text-code-xs-size);
    letter-spacing: var(--text-label-ls);
    text-transform: uppercase;
  }

  .footer__copy {
    font-size: var(--text-code-xs-size);
    color: var(--color-on-surface-variant);
  }

  .footer__links {
    display: flex;
    gap: var(--space-3);
    margin-left: auto;
  }

  .footer__link {
    font-family: var(--font-mono);
    font-size: var(--text-code-xs-size);
    letter-spacing: var(--text-label-ls);
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--c-cyan);
  }

  /* ── Mobile nav ── */
  @media (max-width: 768px) {
    .navbar__links {
      display: none;
    }
  }
</style>
