---
// InteractiveTerminal.astro – HTML & CSS only. 
// JavaScript is loaded from /terminal.js
---

<div class="terminal-wrapper">
  <div class="terminal-container" id="terminalContainer">
    <!-- Terminal Header -->
    <div class="terminal-header">
      <div class="terminal-dots">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>
      <span class="terminal-title">sithila@portfolio:~</span>
    </div>
    
    <!-- Terminal Body -->
    <div class="terminal-body" id="terminalBody">
      <div class="output" id="output">
        <div class="line">
          <span class="prompt">❯</span>
          <span class="text-secondary-container">Welcome to Sithila's interactive terminal!</span>
        </div>
        <div class="line">
          <span class="prompt">❯</span>
          <span class="text-secondary-container">Type <span class="text-primary-container">'help'</span> to see available commands.</span>
        </div>
        <div class="line"></div>
        <div class="line">
          <span class="prompt">❯</span>
          <span class="text-primary-container typewriter">Ready for input_</span>
        </div>
      </div>
      
      <!-- Input Area -->
      <div class="input-area">
        <span class="prompt">❯</span>
        <input 
          type="text" 
          id="terminalInput" 
          class="terminal-input" 
          autofocus
          placeholder="Enter a command..."
          autocomplete="off"
        />
      </div>
    </div>
  </div>
</div>

<!-- Load the external terminal script -->
<script src="/terminal.js" defer></script>

<style>
  .terminal-wrapper {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
  }
  
  .terminal-container {
    background: rgba(10, 10, 20, 0.95);
    border-radius: 12px;
    border: 1px solid rgba(0, 242, 255, 0.2);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8), 0 0 40px rgba(0, 242, 255, 0.05);
    overflow: hidden;
    backdrop-filter: blur(10px);
    cursor: text;
    transition: all 0.3s ease;
    position: relative;
  }
  
  .terminal-container:hover {
    border-color: rgba(0, 242, 255, 0.4);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8), 0 0 60px rgba(0, 242, 255, 0.08);
  }
  
  .terminal-header {
    background: rgba(20, 20, 40, 0.9);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .terminal-dots {
    display: flex;
    gap: 8px;
  }
  
  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  
  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }
  
  .terminal-title {
    color: rgba(255, 255, 255, 0.5);
    font-family: 'Courier New', monospace;
    font-size: 13px;
    margin-left: 8px;
  }
  
  .terminal-body {
    padding: 20px 24px;
    min-height: 400px;
    max-height: 500px;
    overflow-y: auto;
    font-family: 'Courier New', monospace;
    font-size: 14px;
    line-height: 1.8;
    color: #c0caf5;
  }
  
  .terminal-body::-webkit-scrollbar {
    width: 6px;
  }
  
  .terminal-body::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  
  .terminal-body::-webkit-scrollbar-thumb {
    background: rgba(0, 242, 255, 0.3);
    border-radius: 3px;
  }
  
  .terminal-body::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 242, 255, 0.5);
  }
  
  .line {
    margin-bottom: 4px;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  
  .prompt {
    color: #00f2ff;
    font-weight: bold;
    flex-shrink: 0;
  }
  
  .text-white {
    color: #ffffff;
  }
  
  .text-primary-container {
    color: #00f2ff;
  }
  
  .text-secondary-container {
    color: #7aa2f7;
  }
  
  .typewriter {
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  .input-area {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    padding-top: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .terminal-input {
    background: transparent;
    border: none;
    color: #ffffff;
    font-family: 'Courier New', monospace;
    font-size: 14px;
    flex: 1;
    outline: none;
    padding: 4px 0;
  }
  
  .terminal-input::placeholder {
    color: rgba(255, 255, 255, 0.2);
  }
  
  /* Scanline effect */
  .terminal-container::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 242, 255, 0.01) 2px,
      rgba(0, 242, 255, 0.01) 4px
    );
    border-radius: 12px;
  }
  
  /* Responsive */
  @media (max-width: 640px) {
    .terminal-body {
      padding: 16px;
      min-height: 300px;
      max-height: 400px;
      font-size: 12px;
    }
    
    .terminal-title {
      font-size: 11px;
    }
    
    .terminal-input {
      font-size: 12px;
    }
  }
</style>