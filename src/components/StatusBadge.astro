---
export interface Props {
  label: string;
  color?: "primary" | "secondary" | "error";
  pulse?: boolean;
}

const { label, color = "primary", pulse = true } = Astro.props;

const colorMap = {
  primary: "text-primary-container border-primary/20 bg-primary/10",
  secondary: "text-secondary-container border-secondary-container/20 bg-secondary-container/10",
  error: "text-error border-error/20 bg-error/10",
};

const dotColor = {
  primary: "bg-secondary-container",
  secondary: "bg-secondary-container",
  error: "bg-error",
};
---

<div class={`inline-flex items-center gap-2 px-3 py-1 border rounded-full ${colorMap[color]}`}>
  <span class={`w-2 h-2 rounded-full ${dotColor[color]} ${pulse ? 'pulse-green' : ''}`}></span>
  <span class="font-code-xs text-code-xs uppercase tracking-widest">{label}</span>
</div>