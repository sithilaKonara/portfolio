---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import GlassPanel from "../components/GlassPanel.astro";
import TerminalHeader from "../components/TerminalHeader.astro";
import StatusBadge from "../components/StatusBadge.astro";
---

<Layout title="Sithila Konara | Contact">
  <Navigation currentPage="/contact" />
  
  <div class="pt-32 pb-24 px-8 md:px-16 max-w-container_max_width mx-auto">
    <header class="text-center md:text-left space-y-8 mb-">   <!-- ✅ reduced gap -->
      <StatusBadge label="STATUS: OPEN TO OPPORTUNITIES" />
      <h1 class="font-display text-display text-primary uppercase tracking-tighter">
        CONTACT 
      </h1>    
      <p class="font-code-sm text-code-sm text-on-surface-variant uppercase tracking-widest">DECRYPTING COMMUNICATIONS CHANNELS FOR SITHILA_KONARA</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <div class="lg:col-span-8">
        <GlassPanel class="rounded-lg overflow-hidden flex flex-col h-full relative">
          <div class="scanline"></div>
          <TerminalHeader label="sh: cat etc/contacts.yaml" />
          <div class="p-6 md:p-10 flex-grow font-code-sm">
            <div class="mb-8 text-secondary-fixed">
              <p class="mb-1">&gt; fetch --source remote_profile.yaml</p>
              <p class="mb-1 text-on-surface-variant">[ OK ] Record located in encrypted partition.</p>
              <p class="mb-4">&gt; cat etc/contacts.yaml</p>
            </div>
            <div class="space-y-6">
              <div class="grid grid-cols-[120px_1fr] gap-4">
                <span class="text-primary-fixed">EMAIL:</span>
                <span class="text-primary-fixed-dim">kmsithila@gmail.com</span>
              </div>
              <div class="grid grid-cols-[120px_1fr] gap-4">
                <span class="text-primary-fixed">PHONE:</span>
                <span class="text-primary-fixed-dim">+358 417 241 555</span>
              </div>
              <div class="grid grid-cols-[120px_1fr] gap-4 items-start">
                <span class="text-primary-fixed">SOCIALS:</span>
                <div class="space-y-3">
                  <div class="flex items-center gap-4 group">
                    <span class="text-on-surface-variant w-24">GITHUB:</span>
                    <a class="text-primary-fixed-dim hover:text-primary hover:underline transition-colors" href="https://github.com/sithilaKonara/">/GIT/SITHILA</a>
                  </div>
                  <div class="flex items-center gap-4 group">
                    <span class="text-on-surface-variant w-24">LINKEDIN:</span>
                    <a class="text-primary-fixed-dim hover:text-primary hover:underline transition-colors" href="https://www.linkedin.com/in/sithila-konara/">/IN/SITHILA</a>
                  </div>
                  <div class="flex items-center gap-4 group">
                    <span class="text-on-surface-variant w-24">MEDIUM:</span>
                    <a class="text-primary-fixed-dim hover:text-primary hover:underline transition-colors" href="https://medium.com/@sithila_92123">/ME/SITHILA</a>
                  </div>
                </div>
              </div>
              <div class="grid grid-cols-[120px_1fr] gap-4 pt-4 border-t border-outline-variant/30">
                <span class="text-primary-fixed">STATUS:</span>
                <div class="flex items-center gap-2 text-secondary-fixed">
                  <span class="w-2 h-2 rounded-full bg-secondary-container animate-pulse"></span>
                  <span>LISTENING_FOR_INCOMING_TRAFFIC</span>
                </div>
              </div>
            </div>
            <div class="mt-12 p-4 bg-surface-container-low border border-outline-variant/30 rounded">
              <p class="text-on-surface-variant leading-relaxed">
                <span class="text-secondary-fixed"># INFO: Open channel detected.</span><br /> 
                  The best way to reach me is through standard protocols - email, LinkedIn. I respond to all inquiries.
                  No credentials required, just a genuine conversation.
              </p>
            </div>
          </div>
        </GlassPanel>
      </div>
      
      <aside class="lg:col-span-4 flex flex-col gap-8">
        <GlassPanel class="rounded-lg p-6">
          <h3 class="font-label-caps text-label-caps text-primary-fixed mb-6 border-b border-outline-variant pb-2">SYSTEM_STATUS</h3>
          <div class="space-y-4 font-code-xs text-code-xs">
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">NODE_LATENCY:</span>
              <span class="text-secondary-fixed" id="latency-val">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">TIME_ZONE:</span>
              <span class="text-primary-fixed-dim" id="timezone">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">REGION:</span>
              <span class="text-secondary-fixed" id="region">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">UPTIME:</span>
              <span class="text-on-surface" id="uptime">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-surface-variant">ENVIRONMENT:</span>
              <span class="text-on-surface" id="env">—</span>
            </div>
            <div class="mt-6 pt-4 border-t border-outline-variant">
              <div class="w-full h-1 bg-surface-container-high relative overflow-hidden">
                <div class="absolute top-0 left-0 h-full bg-primary-fixed w-1/3 animate-[progress_3s_ease-in-out_infinite]"></div>
              </div>
              <p class="mt-2 text-[10px] text-outline text-right">MONITORING_ACTIVE_NODES...</p>
            </div>
          </div>
        </GlassPanel>
        
        <GlassPanel class="rounded-lg p-6 flex-grow">
          <h3 class="font-label-caps text-label-caps text-primary-fixed mb-6 border-b border-outline-variant pb-2">SOCIAL_NODES</h3>
          <div class="flex flex-col gap-4">
            <a class="group flex items-center justify-between p-4 bg-surface-container-lowest/50 hover:bg-primary-fixed/10 transition-all border border-transparent hover:border-primary-fixed/40" href="https://github.com/sithilaKonara/">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-fixed">code</span>
                <span class="font-code-sm text-code-sm group-hover:text-primary-fixed">GITHUB</span>
              </div>
              <span class="font-code-xs text-code-xs text-outline opacity-0 group-hover:opacity-100 transition-opacity">/GIT/SITHILA</span>
            </a>
            <a class="group flex items-center justify-between p-4 bg-surface-container-lowest/50 hover:bg-primary-fixed/10 transition-all border border-transparent hover:border-primary-fixed/40" href="https://www.linkedin.com/in/sithila-konara/">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-fixed">hub</span>
                <span class="font-code-sm text-code-sm group-hover:text-primary-fixed">LINKEDIN</span>
              </div>
              <span class="font-code-xs text-code-xs text-outline opacity-0 group-hover:opacity-100 transition-opacity">/IN/SITHILA</span>
            </a>
            <a class="group flex items-center justify-between p-4 bg-surface-container-lowest/50 hover:bg-primary-fixed/10 transition-all border border-transparent hover:border-primary-fixed/40" href="https://medium.com/@sithila_92123">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-fixed">history_edu</span>
                <span class="font-code-sm text-code-sm group-hover:text-primary-fixed">MEDIUM</span>
              </div>
              <span class="font-code-xs text-code-xs text-outline opacity-0 group-hover:opacity-100 transition-opacity">/ME/SITHILA</span>
            </a>
          </div>
        </GlassPanel>
      </aside>
    </div>
  </div>
  
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ----- 1. Latency (Targeted In-Place DOM Refresh) -----
    const latencyEl = document.getElementById('latency-val');
    let latencyInterval;

    function measureLatency() {
      const startTime = performance.now();
      
      fetch(window.location.href, { method: 'HEAD', cache: 'no-store' })
        .then((response) => {
          if (response && latencyEl) {
            const latency = Math.round(performance.now() - startTime);
            latencyEl.textContent = latency + 'ms';
          }
        })
        .catch(() => {
          if (latencyEl) latencyEl.textContent = 'N/A';
        });
    }

    measureLatency();
    
    if (latencyInterval) clearInterval(latencyInterval);
    latencyInterval = setInterval(measureLatency, 5000);

    // ----- 2 & 3. Time Zone & Region Parsing -----
    const tzEl = document.getElementById('timezone');
    const regionEl = document.getElementById('region');

    const regionMap: Record<string, string> = {
      'Europe/Helsinki': 'Finland',
      'Europe/Stockholm': 'Sweden',
      'Europe/Oslo': 'Norway',
      'Europe/Copenhagen': 'Denmark',
      'Europe/London': 'United Kingdom',
      'Europe/Berlin': 'Germany',
      'Europe/Paris': 'France',
      'Europe/Rome': 'Italy',
      'Europe/Madrid': 'Spain',
      'Europe/Amsterdam': 'Netherlands',
      'Europe/Zurich': 'Switzerland',
      'Europe/Vienna': 'Austria',
      'Europe/Kiev': 'Ukraine',
      'Europe/Kyiv': 'Ukraine',
      'Europe/Moscow': 'Russia',
      'Europe/Warsaw': 'Poland',
      'Europe/Prague': 'Czechia',
      'Europe/Brussels': 'Belgium',
      'America/New_York': 'US (East)',
      'America/Chicago': 'US (Central)',
      'America/Los_Angeles': 'US (West)',
      'America/Toronto': 'Canada (East)',
      'America/Vancouver': 'Canada (West)',
      'America/Sao_Paulo': 'Brazil',
      'Asia/Tokyo': 'Japan',
      'Asia/Singapore': 'Singapore',
      'Asia/Shanghai': 'China',
      'Asia/Hong_Kong': 'Hong Kong',
      'Asia/Seoul': 'South Korea',
      'Asia/Mumbai': 'India',
      'Asia/Dubai': 'UAE',
      'Australia/Sydney': 'Australia (East)',
      'Australia/Melbourne': 'Australia (East)',
      'Australia/Perth': 'Australia (West)',
      'Pacific/Auckland': 'New Zealand',
    };

    function updateLocationUI(timezoneString: string) {
      if (!tzEl || !regionEl) return;
      tzEl.textContent = timezoneString;
      let displayRegion = regionMap[timezoneString];
      if (!displayRegion) {
        const parts = timezoneString.split('/');
        displayRegion = parts.length > 1 ? parts[1].replace(/_/g, ' ') : timezoneString;
      }
      regionEl.textContent = displayRegion;
    }

    let currentTz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
    updateLocationUI(currentTz);

    fetch('https://ipapi.co/json/')
      .then(res => res.json())
      .then(data => {
        if (data.timezone) {
          updateLocationUI(data.timezone);
        }
      })
      .catch(err => console.log("Using native browser approximation."));

    // ----- 4. Uptime -----
    const uptimeEl = document.getElementById('uptime');
    const start = Date.now();
    function updateUptime() {
      if (!uptimeEl) return;
      const elapsed = Math.floor((Date.now() - start) / 1000);
      const days = String(Math.floor(elapsed / 86400)).padStart(3, '0');
      const hours = String(Math.floor((elapsed % 86400) / 3600)).padStart(2, '0');
      const mins = String(Math.floor((elapsed % 3600) / 60)).padStart(2, '0');
      const secs = String(elapsed % 60).padStart(2, '0');
      uptimeEl.textContent = `${days}:${hours}:${mins}:${secs}`;
    }
    if (uptimeEl) {
      updateUptime();
      setInterval(updateUptime, 1000);
    }

    // ----- 5. Environment -----
    const envEl = document.getElementById('env');
    const ua = navigator.userAgent;
    let env = 'Unknown';
    if (ua.includes('Windows')) env = 'Windows';
    else if (ua.includes('Mac OS')) env = 'macOS';
    else if (ua.includes('Linux')) env = 'Linux';
    else if (ua.includes('Android')) env = 'Android';
    else if (ua.includes('iOS')) env = 'iOS';
    
    let browser = '';
    if (ua.includes('Firefox')) browser = 'Firefox';
    else if (ua.includes('Chrome') && !ua.includes('Edg')) browser = 'Chrome';
    else if (ua.includes('Safari') && !ua.includes('Chrome')) browser = 'Safari';
    else if (ua.includes('Edg')) browser = 'Edge';
    if (envEl) {
      envEl.textContent = browser ? `${browser} · ${env}` : env;
    }
  });
</script>

<style>
  @keyframes progress {
    0% { left: -100%; }
    100% { left: 100%; }
  }
  .pulse-status {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.9); }
  }
</style>