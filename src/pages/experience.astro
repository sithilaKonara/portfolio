---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import GlassPanel from "../components/GlassPanel.astro";
import TerminalHeader from "../components/TerminalHeader.astro";
import StatusBadge from "../components/StatusBadge.astro";
import Certifications from '../components/Certifications.astro';
---

<Layout title="Sithila Konara | Experience">
  <Navigation currentPage="/experience" />
  
  <div class="pt-32 pb-24 px-8 md:px-16 max-w-container_max_width mx-auto">
    <!-- Hero Header -->
     <header class="text-center md:text-left space-y-8 mb-16 ">
      <StatusBadge label="STATUS: OPEN TO OPPORTUNITIES" />
      <h1 class="font-display text-display text-primary uppercase tracking-tighter">
        <span id="totalExperience">12</span> Years <span class="text-primary-container">&amp;</span> Counting
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl border-l-4 border-primary-container pl-6">
        Cloud, DevOps, Platform &amp; SRE with <span id="totalExperience">12</span> years in IT 
        and <span id="sreExperience">7</span>+ years specializing in architecting and operating 
        mission-critical distributed systems. Proven track record of driving cloud cost reduction 
        through FinOps, reducing engineering toil via automation, and maintaining availability 
        across 3000+ servers. Passionate about building secure, self-healing platforms and 
        self-service tools that empower engineering teams to deliver at scale.
      </p>
    </header>
    
    <!-- System Monitoring (Stats) -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-gutter mb-16">
      <GlassPanel class="p-6 border-l-4 border-l-primary-container flex flex-col justify-between">
        <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">Uptime</span>
        <div class="mt-2">
          <span class="font-display text-headline-md text-primary-container">99.99%</span>
        </div>
      </GlassPanel>
      <GlassPanel class="p-6 border-l-4 border-l-secondary-container flex flex-col justify-between">
        <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">Servers</span>
        <div class="mt-2">
          <span class="font-display text-headline-md text-secondary-container">3000+</span>
        </div>
      </GlassPanel>
      <GlassPanel class="p-6 border-l-4 border-l-tertiary-fixed-dim flex flex-col justify-between">
        <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">Cost Saved</span>
        <div class="mt-2 text-tertiary-fixed-dim">
          <span class="font-display text-headline-md">30%</span>
          <span class="font-code-sm text-code-sm ml-1">FINOPs</span>
        </div>
      </GlassPanel>
      <GlassPanel class="p-6 border-l-4 border-l-error flex flex-col justify-between">
        <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">Toil Reduced</span>
        <div class="mt-2 text-error">
          <span class="font-display text-headline-md">35%</span>
          <span class="font-code-sm text-code-sm ml-1">AUTOMATION</span>
        </div>
      </GlassPanel>
    </section>
    
    <!-- Experience + Tech Stack Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Deployment History (Experience) -->
      <section class="lg:col-span-7 space-y-12">
        <h2 class="font-headline-md text-headline-md text-primary flex items-center gap-3">
          <span class="material-symbols-outlined text-primary-container">history</span>
          Deployment History
        </h2>
        <div class="relative pl-8 md:pl-12">
          <!-- Circuit-like Timeline -->
          <div class="absolute left-0 top-0 h-full w-[2px] bg-outline-variant/30"></div>
          
          <!-- Role 1: HCLTECH -->
          <div class="relative mb-16">
            <div class="absolute -left-10 top-2 w-4 h-4 rounded-full border-2 border-primary-container bg-surface flex items-center justify-center z-10">
              <div class="w-1.5 h-1.5 bg-primary-container rounded-full"></div>
            </div>
            <div class="absolute -left-10 top-4 w-10 h-[2px] bg-primary-container/30"></div>
            <GlassPanel class="overflow-hidden">
              <TerminalHeader label="2024 - CURRENT" />
              <div class="p-6 space-y-4">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                  <h3 class="font-headline-md text-headline-md text-primary-container">Site Reliability Engineer</h3>
                  <span class="font-code-sm text-code-sm px-3 py-1 bg-surface-variant rounded border border-outline-variant/50">HCLTECH</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant">
                  I design secure, self-service infrastructure that handles the complexity of global scale 
                  so engineers can focus on shipping code. By combining least‑privilege IAM with dynamic secrets management, 
                  I've created environments that are both bulletproof and frictionless reducing security headaches and deployment delays.
                </p>
                <ul class="font-code-sm text-code-sm space-y-2 text-secondary-fixed-dim">
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Built self‑service tools eliminating manual workflows – improved team efficiency by 30%.
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Designed secure, automated CI/CD pipelines with GitHub Actions.
                  </li>
                </ul>
              </div>
            </GlassPanel>
          </div>
          
          <!-- Role 2: PEARSON (Associate Technical Specialist) -->
          <div class="relative mb-16">
            <div class="absolute -left-10 top-2 w-4 h-4 rounded-full border-2 border-primary-container/50 bg-surface flex items-center justify-center z-10">
              <div class="w-1.5 h-1.5 bg-primary-container/50 rounded-full"></div>
            </div>
            <div class="absolute -left-10 top-4 w-10 h-[2px] bg-primary-container/20"></div>
            <GlassPanel class="overflow-hidden">
              <TerminalHeader label="2022 - 2023" />
              <div class="p-6 space-y-4">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                  <h3 class="font-headline-md text-headline-md text-primary">Associate Technical Specialist</h3>
                  <span class="font-code-sm text-code-sm px-3 py-1 bg-surface-variant rounded border border-outline-variant/50">PEARSON</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant">
                  Architected and deployed robust, scalable cloud infrastructure using the Well‑Architected Framework
                  with a focus on security and high availability. Drove FinOps initiatives surfacing cost visibility
                  to engineering teams.
                </p>
                <ul class="font-code-sm text-code-sm space-y-2 text-on-surface-variant/80">
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Reduced monthly cloud spend by 30% through proactive resource optimization.
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Implemented Infrastructure‑as‑Code with Terraform – achieved 1‑day RTO in disaster recovery.
                  </li>
                </ul>
              </div>
            </GlassPanel>
          </div>
          
          <!-- Role 3: PEARSON (Senior System Engineer) -->
          <div class="relative mb-16">
            <div class="absolute -left-10 top-2 w-4 h-4 rounded-full border-2 border-primary-container/30 bg-surface flex items-center justify-center z-10">
              <div class="w-1.5 h-1.5 bg-primary-container/30 rounded-full"></div>
            </div>
            <div class="absolute -left-10 top-4 w-10 h-[2px] bg-primary-container/10"></div>
            <GlassPanel class="overflow-hidden">
              <TerminalHeader label="2018 - 2022" />
              <div class="p-6 space-y-4">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                  <h3 class="font-headline-md text-headline-md text-primary">Senior System Engineer</h3>
                  <span class="font-code-sm text-code-sm px-3 py-1 bg-surface-variant rounded border border-outline-variant/50">PEARSON</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant">
                  Operated and maintained large‑scale hybrid cloud platforms (3000+ servers) with 99% availability.
                  Built observability standards and conducted root cause analysis for service outages.
                </p>
                <ul class="font-code-sm text-code-sm space-y-2 text-on-surface-variant/80">
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Automated patching processes – achieved 90% success rate, reducing manual effort by 80%.
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Managed large‑scale EOL server migrations, reducing EOL footprint by 35%.
                  </li>
                </ul>
              </div>
            </GlassPanel>
          </div>
          
          <!-- Role 4: INVOLVE 360 -->
          <div class="relative mb-16">
            <div class="absolute -left-10 top-2 w-4 h-4 rounded-full border-2 border-primary-container/20 bg-surface flex items-center justify-center z-10">
              <div class="w-1.5 h-1.5 bg-primary-container/20 rounded-full"></div>
            </div>
            <div class="absolute -left-10 top-4 w-10 h-[2px] bg-primary-container/10"></div>
            <GlassPanel class="overflow-hidden">
              <TerminalHeader label="2016 - 2018" />
              <div class="p-6 space-y-4">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                  <h3 class="font-headline-md text-headline-md text-primary">Infrastructure Management Engineer</h3>
                  <span class="font-code-sm text-code-sm px-3 py-1 bg-surface-variant rounded border border-outline-variant/50">INVOLVE 360</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant">
                  Provided NOC support to MSPs in the US, UK, Australia, and Canada. Troubleshot server infrastructure
                  issues, performed server migrations, and implemented monitoring best practices.
                </p>
                <ul class="font-code-sm text-code-sm space-y-2 text-on-surface-variant/80">
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Managed Windows/VMware/Hyper‑V/Azure environments for global clients.
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Implemented proactive monitoring and alerting for critical infrastructure.
                  </li>
                </ul>
              </div>
            </GlassPanel>
          </div>
          
          <!-- Role 5: KBSL -->
          <div class="relative mb-16">
            <div class="absolute -left-10 top-2 w-4 h-4 rounded-full border-2 border-primary-container/20 bg-surface flex items-center justify-center z-10">
              <div class="w-1.5 h-1.5 bg-primary-container/20 rounded-full"></div>
            </div>
            <div class="absolute -left-10 top-4 w-10 h-[2px] bg-primary-container/10"></div>
            <GlassPanel class="overflow-hidden">
              <TerminalHeader label="2015 - 2016" />
              <div class="p-6 space-y-4">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                  <h3 class="font-headline-md text-headline-md text-primary">Systems Engineer</h3>
                  <span class="font-code-sm text-code-sm px-3 py-1 bg-surface-variant rounded border border-outline-variant/50">KBSL INFORMATION TECHNOLOGIES</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant">
                  Administered ISP core network infrastructure, configuring IP networking, routing protocols,
                  high availability, VPNs, and firewalling to enforce network security.
                </p>
                <ul class="font-code-sm text-code-sm space-y-2 text-on-surface-variant/80">
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Managed Cisco IOS XR, Juniper EX4550, and Palo Alto 5050 firewalls.
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Configured VLANs, NAT, EBGP/IBGP, and system hardening (ACLs).
                  </li>
                </ul>
              </div>
            </GlassPanel>
          </div>
          
          <!-- Role 6: 99X -->
          <div class="relative">
            <div class="absolute -left-10 top-2 w-4 h-4 rounded-full border-2 border-primary-container/10 bg-surface flex items-center justify-center z-10">
              <div class="w-1.5 h-1.5 bg-primary-container/10 rounded-full"></div>
            </div>
            <div class="absolute -left-10 top-4 w-10 h-[2px] bg-primary-container/5"></div>
            <GlassPanel class="overflow-hidden">
              <TerminalHeader label="2013 - 2015" />
              <div class="p-6 space-y-4">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                  <h3 class="font-headline-md text-headline-md text-primary">System Support Technician</h3>
                  <span class="font-code-sm text-code-sm px-3 py-1 bg-surface-variant rounded border border-outline-variant/50">99X SERVICES</span>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant">
                  Provided system support and maintenance for enterprise clients, troubleshooting hardware and
                  software issues in mixed Windows/Linux environments.
                </p>
                <ul class="font-code-sm text-code-sm space-y-2 text-on-surface-variant/80">
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Resolved critical system incidents, ensuring minimal downtime.
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined text-sm pt-1">chevron_right</span>
                    Assisted in server deployment and routine maintenance tasks.
                  </li>
                </ul>
              </div>
            </GlassPanel>
          </div>
        </div>
      </section>
      
      <!-- Tech Stack (Skills) -->
      <aside class="lg:col-span-5 space-y-12">
        <h2 class="font-headline-md text-headline-md text-primary flex items-center gap-3">
          <span class="material-symbols-outlined text-primary-container">hub</span>
          Tech Stack
        </h2>
        <div class="grid grid-cols-1 gap-6">
          <!-- Cloud -->
          <div class="space-y-3">
            <h4 class="font-label-caps text-label-caps text-primary-container/70 border-b border-primary-container/20 pb-1">01_CLOUD_INFRA</h4>
            <div class="flex flex-wrap gap-2">
              {["AWS", "GCP"].map(tag => (
                <span class="px-3 py-1.5 bg-surface border border-primary-container/40 text-primary-container font-code-sm text-code-sm shadow-[0_0_10px_rgba(0,242,255,0.1)]">{tag}</span>
              ))}
            </div>
          </div>
          <!-- DevOps Tools -->
          <div class="space-y-3">
            <h4 class="font-label-caps text-label-caps text-secondary-container/70 border-b border-secondary-container/20 pb-1">02_DEVOPS_TOOLING</h4>
            <div class="flex flex-wrap gap-2">
              {["TERRAFORM", "ANSIBLE", "KUBERNETES", "DOCKER", "GITHUB ACTIONS"].map(tag => (
                <span class="px-3 py-1.5 bg-surface border border-secondary-container/40 text-secondary-container font-code-sm text-code-sm shadow-[0_0_10px_rgba(47,248,1,0.1)]">{tag}</span>
              ))}
            </div>
          </div>
          <!-- Programming -->
          <div class="space-y-3">
            <h4 class="font-label-caps text-label-caps text-tertiary-fixed-dim/70 border-b border-tertiary-fixed-dim/20 pb-1">03_LANGUAGES</h4>
            <div class="flex flex-wrap gap-2">
              {["PYTHON", "BASH"].map(tag => (
                <span class="px-3 py-1.5 bg-surface border border-tertiary-fixed-dim/40 text-tertiary-fixed-dim font-code-sm text-code-sm shadow-[0_0_10px_rgba(235,178,255,0.1)]">{tag}</span>
              ))}
            </div>
          </div>
          <!-- Observability -->
          <div class="space-y-3">
            <h4 class="font-label-caps text-label-caps text-error/70 border-b border-error/20 pb-1">04_OBSERVABILITY</h4>
            <div class="flex flex-wrap gap-2">
              {["CLOUDWATCH", "GRAFANA", "PROMETHEUS"].map(tag => (
                <span class="px-3 py-1.5 bg-surface border border-error/40 text-error font-code-sm text-code-sm shadow-[0_0_10px_rgba(255,180,171,0.1)]">{tag}</span>
              ))}
            </div>
          </div>
          <!-- Security -->
          <div class="space-y-3">
            <h4 class="font-label-caps text-label-caps text-primary-container/70 border-b border-primary-container/20 pb-1">05_SECURITY</h4>
            <div class="flex flex-wrap gap-2">
              {["IAM", "VAULT"].map(tag => (
                <span class="px-3 py-1.5 bg-surface border border-primary-container/40 text-primary-container font-code-sm text-code-sm shadow-[0_0_10px_rgba(0,242,255,0.1)]">{tag}</span>
              ))}
            </div>
          </div>
          <!-- Networking -->
          <div class="space-y-3">
            <h4 class="font-label-caps text-label-caps text-secondary-container/70 border-b border-secondary-container/20 pb-1">06_NETWORKING</h4>
            <div class="flex flex-wrap gap-2">
              {["VPC", "DNS", "LOAD BALANCING", "FIREWALLS", "SECURITY GROUPS", "ACL"].map(tag => (
                <span class="px-3 py-1.5 bg-surface border border-secondary-container/40 text-secondary-container font-code-sm text-code-sm shadow-[0_0_10px_rgba(47,248,1,0.1)]">{tag}</span>
              ))}
            </div>
          </div>
          <!-- FinOps -->
          <div class="space-y-3">
            <h4 class="font-label-caps text-label-caps text-tertiary-fixed-dim/70 border-b border-tertiary-fixed-dim/20 pb-1">07_FINOPS</h4>
            <div class="flex flex-wrap gap-2">
              {["COST OPTIMIZATION", "COST VISIBILITY"].map(tag => (
                <span class="px-3 py-1.5 bg-surface border border-tertiary-fixed-dim/40 text-tertiary-fixed-dim font-code-sm text-code-sm shadow-[0_0_10px_rgba(235,178,255,0.1)]">{tag}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Certifications -->
        <Certifications />
        
      </aside>
    </div>
  </div>  
  <Footer />
</Layout>