---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import GlassPanel from "../components/GlassPanel.astro";
import TerminalHeader from "../components/TerminalHeader.astro";
import StatusBadge from "../components/StatusBadge.astro";
import Certifications from "../components/Certifications.astro";
import Data from "../data/staticdata.json";

const { metrics, workExperience, techStack } = Data;

// Style mappings for metrics cards
const metricBorderColors = [
  "border-l-primary-container",
  "border-l-secondary-container",
  "border-l-tertiary-fixed-dim",
  "border-l-error",
];

const metricTextColors = [
  "text-primary-container",
  "text-secondary-container",
  "text-tertiary-fixed-dim",
  "text-error",
];

// Style mappings for tech stack categories
const categoryStyles = [
  {
    header: "text-primary-container/70 border-primary-container/20",
    tag: "border-primary-container/40 text-primary-container shadow-[0_0_10px_rgba(0,242,255,0.1)]",
  },
  {
    header: "text-secondary-container/70 border-secondary-container/20",
    tag: "border-secondary-container/40 text-secondary-container shadow-[0_0_10px_rgba(47,248,1,0.1)]",
  },
  {
    header: "text-tertiary-fixed-dim/70 border-tertiary-fixed-dim/20",
    tag: "border-tertiary-fixed-dim/40 text-tertiary-fixed-dim shadow-[0_0_10px_rgba(235,178,255,0.1)]",
  },
  {
    header: "text-error/70 border-error/20",
    tag: "border-error/40 text-error shadow-[0_0_10px_rgba(255,180,171,0.1)]",
  },
];

const formatCategoryTitle = (key: string, index: number) => {
  const num = String(index + 1).padStart(2, "0");
  const formattedKey = key.replace(/([A-Z])/g, "_$1").toUpperCase();
  return `${num}_${formattedKey}`;
};
---

<Layout title="Sithila Konara | Experience">
  <Navigation currentPage="/experience" />

  <div class="pt-32 pb-24 px-8 md:px-16 max-w-container_max_width mx-auto">
    <!-- Hero Header -->
    <header class="text-center md:text-left space-y-8 mb-16">
      <StatusBadge label="STATUS: OPEN TO OPPORTUNITIES" />
      <h1
        class="font-display text-display text-primary uppercase tracking-tighter"
      >
        <span id="totalExperience">12</span> Years <span
          class="text-primary-container">&amp;</span
        > Counting
      </h1>
      <p
        class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl border-l-4 border-primary-container pl-6"
      >
        Cloud, DevOps, Platform &amp; SRE with <span id="totalExperience"
          >12</span
        > years in IT and <span id="sreExperience">7</span>+ years specializing
        in architecting and operating mission-critical distributed systems.
        Proven track record of driving cloud cost reduction through FinOps,
        reducing engineering toil via automation, and maintaining availability
        across 3000+ servers. Passionate about building secure, self-healing
        platforms and self-service tools that empower engineering teams to
        deliver at scale.
      </p>
    </header>

    <!-- System Monitoring (Stats) -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-gutter mb-16">
      {
        metrics.map((metric, index) => {
          const borderColor =
            metricBorderColors[index % metricBorderColors.length];
          const textColor = metricTextColors[index % metricTextColors.length];

          // Separate value into primary stat and secondary label if space/unit exists
          const parts = metric.value.split(" ");
          const mainVal = parts[0];
          const subVal = parts.slice(1).join(" ");

          return (
            <GlassPanel
              class={`p-6 border-l-4 ${borderColor} flex flex-col justify-between`}
            >
              <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">
                {metric.label}
              </span>
              <div class={`mt-2 ${textColor}`}>
                <span class="font-display text-headline-md">{mainVal}</span>
                {subVal && (
                  <span class="font-code-sm text-code-sm ml-1">{subVal}</span>
                )}
              </div>
            </GlassPanel>
          );
        })
      }
    </section>

    <!-- Experience + Tech Stack Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Deployment History (Experience) -->
      <section class="lg:col-span-7 space-y-12">
        <h2
          class="font-headline-md text-headline-md text-primary flex items-center gap-3"
        >
          <span class="material-symbols-outlined text-primary-container"
            >history</span
          >
          Deployment History
        </h2>
        <div class="relative pl-8 md:pl-12">
          <!-- Circuit-like Timeline -->
          <div
            class="absolute left-0 top-0 h-full w-[2px] bg-outline-variant/30"
          >
          </div>

          {
            workExperience.map((role, idx) => {
              const isCurrent = idx === 0;

              // Dynamic opacity classes
              const nodeBorder = isCurrent
                ? "border-primary-container"
                : idx === 1
                  ? "border-primary-container/50"
                  : idx === 2
                    ? "border-primary-container/30"
                    : "border-primary-container/20";
              const nodeDot = isCurrent
                ? "bg-primary-container"
                : idx === 1
                  ? "bg-primary-container/50"
                  : idx === 2
                    ? "bg-primary-container/30"
                    : "bg-primary-container/20";
              const connectorLine = isCurrent
                ? "bg-primary-container/30"
                : idx === 1
                  ? "bg-primary-container/20"
                  : idx === 2
                    ? "bg-primary-container/10"
                    : "bg-primary-container/5";
              const titleColor = isCurrent
                ? "text-primary-container"
                : "text-primary";
              const highlightTextColor = isCurrent
                ? "text-secondary-fixed-dim"
                : "text-on-surface-variant/80";

              return (
                <div class="relative mb-16 last:mb-0">
                  {/* Timeline Circuit Node */}
                  <div
                    class={`absolute -left-10 top-2 w-4 h-4 rounded-full border-2 ${nodeBorder} bg-surface flex items-center justify-center z-10`}
                  >
                    <div class={`w-1.5 h-1.5 ${nodeDot} rounded-full`} />
                  </div>
                  <div
                    class={`absolute -left-10 top-4 w-10 h-[2px] ${connectorLine}`}
                  />

                  <GlassPanel class="overflow-hidden">
                    <TerminalHeader label={role.period} />
                    <div class="p-6 space-y-4">
                      <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                        <h3
                          class={`font-headline-md text-headline-md ${titleColor}`}
                        >
                          {role.role}
                        </h3>
                        <span class="font-code-sm text-code-sm px-3 py-1 bg-surface-variant rounded border border-outline-variant/50">
                          {role.company}
                        </span>
                      </div>
                      <p class="font-body-md text-body-md text-on-surface-variant">
                        {role.description}
                      </p>
                      {role.highlights && role.highlights.length > 0 && (
                        <ul
                          class={`font-code-sm text-code-sm space-y-2 ${highlightTextColor}`}
                        >
                          {role.highlights.map((highlight) => (
                            <li class="flex items-start gap-2">
                              <span class="material-symbols-outlined text-sm pt-1">
                                chevron_right
                              </span>
                              <span>{highlight}</span>
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </GlassPanel>
                </div>
              );
            })
          }
        </div>
      </section>

      <!-- Tech Stack (Skills) -->
      <aside class="lg:col-span-5 space-y-12">
        <h2
          class="font-headline-md text-headline-md text-primary flex items-center gap-3"
        >
          <span class="material-symbols-outlined text-primary-container"
            >hub</span
          >
          Tech Stack
        </h2>

        <div class="grid grid-cols-1 gap-6">
          {
            Object.entries(techStack).map(([category, items], index) => {
              const style = categoryStyles[index % categoryStyles.length];
              return (
                <div class="space-y-3">
                  <h4
                    class={`font-label-caps text-label-caps border-b pb-1 ${style.header}`}
                  >
                    {formatCategoryTitle(category, index)}
                  </h4>
                  <div class="flex flex-wrap gap-2">
                    {items.map((tag) => (
                      <span
                        class={`px-3 py-1.5 bg-surface border font-code-sm text-code-sm ${style.tag}`}
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              );
            })
          }
        </div>

        <!-- Certifications -->
        <Certifications />
      </aside>
    </div>
  </div>
  <Footer />
</Layout>
