---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import GlassPanel from "../components/GlassPanel.astro";
import { GithubActivity } from "astro-github-activity";
import StatusBadge from "../components/StatusBadge.astro";
import reposData from "../data/repos.json";
import statsData from "../data/github-stats.json";

const repos = Array.isArray(reposData) ? reposData : [];
repos.sort((a, b) => (b.stars || 0) - (a.stars || 0));

const GITHUB_USERNAME = "sithilakonara";

// Language colour map (matches fetch-github.py)
const LANG_COLORS: Record<string, string> = {
  "Python": "#3572A5",
  "TypeScript": "#3178C6",
  "JavaScript": "#F1E05A",
  "Go": "#00ADD8",
  "Rust": "#CE422B",
  "HCL": "#844FBA",
  "Shell": "#89E051",
  "Dockerfile": "#384D54",
  "HTML": "#E34C26",
  "CSS": "#563D7C",
  "Java": "#B07219",
  "C++": "#F34B7D",
  "Other": "#849495"
};
---

<Layout title="Sithila Konara | Projects">
  <Navigation currentPage="/projects" />
  
  <div class="pt-32 pb-24 px-8 md:px-16 max-w-container_max_width mx-auto">
    <!-- HEADER SECTION -->
    <header class="text-center md:text-left space-y-8 mb-16">
      <StatusBadge label="STATUS: OPEN TO OPPORTUNITIES" />
      <h1 class="font-display text-display text-primary uppercase tracking-tighter">
        PROJECTS
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl border-l-4 border-primary-container pl-6">
        I build because production breaks. I share because someone else's fix might be the one I need tomorrow.
        Every repo here is a lesson learned the hard way turned into code so we both get smarter, faster.
      </p>
    </header>
    
    <!-- PROJECT GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
      {
        repos.map((repo, index) => {
          const name = repo.name || "Unnamed Repo";
          const description = repo.description || "No description provided.";
          const stars = repo.stars ?? 0;
          const forks = repo.forks ?? 0;
          const topics = repo.topics || [];
          const language = repo.language || "";
          const url = repo.url || "#";
          const updatedAt = repo.updatedAt || "Unknown";
          const repoId = name.replace(/[^a-zA-Z0-9]/g, '_').toUpperCase() || `R${index+1}`;
          
          return (
            <div class="glass-panel group relative overflow-hidden flex flex-col">
              <div class="h-8 bg-surface-container-highest px-4 flex items-center justify-between border-b border-outline-variant">
                <div class="flex gap-1.5">
                  <div class="w-2.5 h-2.5 rounded-full bg-error/40"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-secondary-fixed/40"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-primary-fixed/40"></div>
                </div>
                <span class="font-code-xs text-[10px] text-on-surface-variant/50">~/{name}</span>
              </div>
              <div class="p-8 flex-grow flex flex-col">
                <div class="flex justify-between items-start mb-6">
                  <div>
                    <h3 class="font-headline-md text-headline-md text-primary-fixed mb-2">{name}</h3>
                    <div class="flex flex-wrap gap-2">
                      {topics.map(tag => (
                        <span class="px-2 py-0.5 border border-primary-fixed text-primary-fixed font-code-xs text-[10px] uppercase">{tag}</span>
                      ))}
                      {topics.length === 0 && language && (
                        <span class="px-2 py-0.5 border border-primary-fixed text-primary-fixed font-code-xs text-[10px] uppercase">{language}</span>
                      )}
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="flex items-center gap-1 text-secondary-fixed font-code-sm">
                      <span class="material-symbols-outlined text-[18px]">star</span> {stars}
                    </div>
                    <div class="flex items-center gap-1 text-on-surface-variant font-code-sm">
                      <span class="material-symbols-outlined text-[18px]">fork_left</span> {forks}
                    </div>
                  </div>
                </div>
                <p class="text-on-surface-variant mb-8 leading-relaxed font-body-md flex-grow">
                  {description}
                </p>

                {/* ✨ LANGUAGE BREAKDOWN BAR + LEGEND */}
                {repo.languages && Object.keys(repo.languages).length > 0 && (
                  <div class="mt-4 mb-4">
                    {/* The bar */}
                    <div class="flex h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                      {(() => {
                        const total = Object.values(repo.languages).reduce((a, b) => a + b, 0);
                        const entries = Object.entries(repo.languages)
                          .sort((a, b) => b[1] - a[1])
                          .slice(0, 8);
                        return entries.map(([lang, bytes]) => {
                          const percent = (bytes / total) * 100;
                          const color = LANG_COLORS[lang] || LANG_COLORS["Other"];
                          return <div class="h-full" style={{ width: `${percent}%`, backgroundColor: color }} title={`${lang}: ${percent.toFixed(1)}%`} />;
                        });
                      })()}
                    </div>
                    {/* Legend */}
                    <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2">
                      {(() => {
                        const total = Object.values(repo.languages).reduce((a, b) => a + b, 0);
                        const entries = Object.entries(repo.languages)
                          .sort((a, b) => b[1] - a[1])
                          .slice(0, 8);
                        return entries.map(([lang, bytes]) => {
                          const percent = (bytes / total) * 100;
                          const color = LANG_COLORS[lang] || LANG_COLORS["Other"];
                          return (
                            <span class="flex items-center gap-1.5 font-code-xs text-[10px] text-on-surface-variant">
                              <span class="inline-block w-2.5 h-2.5 rounded-sm" style={{ backgroundColor: color }}></span>
                              {lang} <span class="text-primary-fixed/60">{percent.toFixed(1)}%</span>
                            </span>
                          );
                        });
                      })()}
                    </div>
                  </div>
                )}

                {/* Terminal block */}
                <div class="bg-surface-container-lowest p-4 rounded border border-outline-variant font-code-xs text-secondary-fixed mb-8 overflow-hidden">
                  <span class="opacity-50">$</span> git clone <span class="break-all">{url}</span> <br />
                  <span class="opacity-50">[OK]</span> Updated: {updatedAt}
                </div>
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full py-4 border border-primary-fixed text-primary-fixed font-label-caps text-label-caps hover:bg-primary-fixed hover:text-on-primary shadow-[0_0_0px_#74f5ff] hover:shadow-[0_0_20px_rgba(116,245,255,0.4)] transition-all text-center"
                >
                  EXECUTE_VIEW_SOURCE --REPO={repoId}
                </a>
              </div>
            </div>
          );
        })
      }
    </div>
    
    <!-- STATISTICS SECTION -->
    <section class="mb-24">
      <!-- 👇 Heading stays visible on all screens -->
      <h2 class="font-label-caps text-label-caps text-primary-fixed-dim tracking-widest mb-8 flex items-center gap-3">
        <span class="material-symbols-outlined">analytics</span> GITHUB_ANALYTICS
      </h2>

      <!-- 👇 Graph container hidden on mobile, visible on md+ -->
      <div class="hidden md:block">
        <div class="grid grid-cols-1 lg:grid-cols-1 gap-8">
          <div class="lg:col-span-2 glass-panel p-8">
            <div class="flex justify-between items-center mb-6">
              <span class="font-code-sm text-on-surface-variant">Contribution Matrix (365 Days)</span>
            </div>
            <GithubActivity user={GITHUB_USERNAME} theme="dark" />
          </div>
        </div>
      </div>
      
      {statsData && typeof statsData === 'object' && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          <GlassPanel class="p-6 border-l-4 border-l-primary-container flex flex-col justify-between">
            <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">Total Repos</span>
            <div class="mt-2">
              <span class="font-display text-headline-md text-primary-container">
                {statsData.totalRepos ?? repos.length}
              </span>
            </div>
          </GlassPanel>

          <GlassPanel class="p-6 border-l-4 border-l-secondary-container flex flex-col justify-between">
            <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">Total Stars</span>
            <div class="mt-2">
              <span class="font-display text-headline-md text-secondary-container">
                {statsData.totalStars ?? repos.reduce((acc, r) => acc + (r.stars || 0), 0)}
              </span>
            </div>
          </GlassPanel>

          <GlassPanel class="p-6 border-l-4 border-l-tertiary-fixed-dim flex flex-col justify-between">
            <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">Total Forks</span>
            <div class="mt-2">
              <span class="font-display text-headline-md text-tertiary-fixed-dim">
                {statsData.totalForks ?? repos.reduce((acc, r) => acc + (r.forks || 0), 0)}
              </span>
            </div>
          </GlassPanel>

          <GlassPanel class="p-6 border-l-4 border-l-error flex flex-col justify-between">
            <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">Languages</span>
            <div class="mt-2">
              <span class="font-display text-headline-md text-error">
                {statsData.languages ? Object.keys(statsData.languages).length : "—"}
              </span>
            </div>
          </GlassPanel>
        </div>
      )}
    </section>
    
    <!-- CALL TO ACTION -->
    <section class="glass-panel p-6 md:p-12 lg:p-16 text-center relative overflow-hidden border-primary-fixed/30 shadow-[0_0_30px_rgba(116,245,255,0.05)]">
      <div class="absolute inset-0 bg-gradient-to-t from-primary-fixed/5 to-transparent"></div>
      <div class="relative z-10">
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-display text-primary-fixed uppercase mb-4">
          WANT_TO_COLLABORATE?
        </h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant mb-10 max-w-xl mx-auto">
          ___________________________________________
        </p>
        <a
          href="https://github.com/sithilaKonara?tab=repositories"
          target="_blank"
          rel="noopener noreferrer"
          class="group px-6 sm:px-8 py-4 bg-primary-fixed text-on-primary-fixed font-label-caps text-sm sm:text-base font-bold uppercase tracking-widest hover:shadow-[0_0_30px_#74f5ff] transition-all flex items-center justify-center gap-3 mx-auto w-fit"
        >
          [Open GitHub]
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>
    </section>
  </div>
  
  <Footer />
</Layout>

<style>
  .terminal-cursor::after {
    content: '_';
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }
</style>