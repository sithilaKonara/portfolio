---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import GlassPanel from "../components/GlassPanel.astro";
import TerminalHeader from "../components/TerminalHeader.astro";
import { GithubActivity } from "astro-github-activity";

const GITHUB_USERNAME = "sithilakonara";
---

<Layout title="Sithila Konara // Projects">
  <Navigation currentPage="/projects" />
  
  <div class="pt-32 pb-24 px-8 md:px-16 max-w-container_max_width mx-auto">
    <!-- HEADER SECTION -->
    <header class="mb-16">
      <div class="flex items-center gap-4 mb-4">
        <div class="h-[1px] flex-grow bg-outline-variant"></div>
        <span class="font-code-xs text-code-xs text-secondary-fixed uppercase tracking-tighter">System_Status: Optimal</span>
        <div class="h-[1px] w-12 bg-outline-variant"></div>
      </div>
      <h1 class="font-display text-display text-primary-fixed-dim uppercase mb-6 flex items-center gap-4">
        REPOS_&amp;_SYSTEMS
        <span class="inline-block w-8 h-12 bg-primary-fixed terminal-cursor"></span>
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl leading-relaxed">
        Architecting high-availability infrastructure and automated governance.
        Below is a catalog of specialized tooling for cloud-native resilience,
        security auditing, and CI/CD engineering.
      </p>
    </header>
    
    <!-- FILTER TABS -->
    <div class="flex flex-wrap gap-2 mb-12">
      <button class="px-6 py-2 bg-primary-fixed text-on-primary-fixed font-label-caps text-label-caps uppercase tracking-widest hover:shadow-[0_0_15px_#74f5ff] transition-all">All_Modules</button>
      <button class="px-6 py-2 border border-outline-variant text-on-surface-variant font-label-caps text-label-caps uppercase tracking-widest hover:border-primary-fixed hover:text-primary-fixed transition-all">Cloud_Native</button>
      <button class="px-6 py-2 border border-outline-variant text-on-surface-variant font-label-caps text-label-caps uppercase tracking-widest hover:border-primary-fixed hover:text-primary-fixed transition-all">Security</button>
      <button class="px-6 py-2 border border-outline-variant text-on-surface-variant font-label-caps text-label-caps uppercase tracking-widest hover:border-primary-fixed hover:text-primary-fixed transition-all">Automation</button>
    </div>
    
    <!-- PROJECT GRID (BENTO INSPIRED) -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-24">
      <!-- Project 1: Kubernetes Controller -->
      <div class="md:col-span-7 glass-panel group relative overflow-hidden flex flex-col">
        <div class="h-8 bg-surface-container-highest px-4 flex items-center justify-between border-b border-outline-variant">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-error/40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-secondary-fixed/40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-primary-fixed/40"></div>
          </div>
          <span class="font-code-xs text-[10px] text-on-surface-variant/50">~/src/k8s_controller.go</span>
        </div>
        <div class="p-8 flex-grow">
          <div class="flex justify-between items-start mb-6">
            <div>
              <h3 class="font-headline-md text-headline-md text-primary-fixed mb-2">Custom Kubernetes Controller</h3>
              <div class="flex flex-wrap gap-2">
                {["Golang", "Kubernetes SDK", "Operator SDK"].map(tag => (
                  <span class="px-2 py-0.5 border border-primary-fixed text-primary-fixed font-code-xs text-[10px] uppercase">{tag}</span>
                ))}
              </div>
            </div>
            <div class="text-right">
              <div class="flex items-center gap-1 text-secondary-fixed font-code-sm">
                <span class="material-symbols-outlined text-[18px]">star</span> 12.4k
              </div>
              <div class="flex items-center gap-1 text-on-surface-variant font-code-sm">
                <span class="material-symbols-outlined text-[18px]">fork_left</span> 842
              </div>
            </div>
          </div>
          <p class="text-on-surface-variant mb-8 leading-relaxed font-body-md">
            A robust operator designed to automate the lifecycle of stateful database clusters within multi-region Kubernetes deployments. Implements custom reconciliation logic to ensure 99.999% uptime during complex rolling updates.
          </p>
          <div class="bg-surface-container-lowest p-4 rounded border border-outline-variant font-code-xs text-secondary-fixed mb-8">
            <span class="opacity-50">$</span> kubectl logs controller-pod-8fx2 <br />
            <span class="opacity-50">[INFO]</span> Reconciliation loop started for namespace: prod-us-east-1 <br />
            <span class="opacity-50">[OK]</span> 124 Pods verified, No drift detected.
          </div>
          <button class="w-full py-4 border border-primary-fixed text-primary-fixed font-label-caps text-label-caps hover:bg-primary-fixed hover:text-on-primary shadow-[0_0_0px_#74f5ff] hover:shadow-[0_0_20px_rgba(116,245,255,0.4)] transition-all">
            EXECUTE_VIEW_SOURCE --REPO=0x1A
          </button>
        </div>
      </div>
      
      <!-- Project 2: Cloud Sentinel -->
      <div class="md:col-span-5 glass-panel group relative overflow-hidden flex flex-col">
        <div class="h-8 bg-surface-container-highest px-4 flex items-center justify-between border-b border-outline-variant">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-error/40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-secondary-fixed/40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-primary-fixed/40"></div>
          </div>
          <span class="font-code-xs text-[10px] text-on-surface-variant/50">~/security/auditor.py</span>
        </div>
        <div class="p-8 flex-grow flex flex-col">
          <h3 class="font-headline-md text-headline-md text-tertiary-fixed-dim mb-2">Cloud Sentinel Auditor</h3>
          <div class="flex flex-wrap gap-2 mb-6">
            {["AWS Boto3", "Python"].map(tag => (
              <span class="px-2 py-0.5 border border-tertiary-fixed text-tertiary-fixed font-code-xs text-[10px] uppercase">{tag}</span>
            ))}
          </div>
          <p class="text-on-surface-variant mb-8 flex-grow font-body-md">
            Real-time security governance tool that scans IAM roles and S3 buckets for excessive permissions, automatically remediating vulnerabilities using Lambda functions.
          </p>
          <div class="flex justify-between items-end">
            <div class="text-secondary-fixed/70 font-code-sm">
              <span class="block text-[10px] uppercase opacity-50">Impact</span>
              7.2k Scans/Day
            </div>
            <button class="p-3 border border-primary-fixed text-primary-fixed hover:bg-primary-fixed hover:text-on-primary transition-all">
              <span class="material-symbols-outlined">terminal</span>
            </button>
          </div>
        </div>
      </div>
      
      <!-- Project 3: Terraform Recovery -->
      <div class="md:col-span-5 glass-panel group relative overflow-hidden flex flex-col">
        <div class="h-8 bg-surface-container-highest px-4 flex items-center justify-between border-b border-outline-variant">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-error/40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-secondary-fixed/40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-primary-fixed/40"></div>
          </div>
          <span class="font-code-xs text-[10px] text-on-surface-variant/50">~/infra/disaster_recovery.hcl</span>
        </div>
        <div class="p-8 flex-grow flex flex-col">
          <h3 class="font-headline-md text-headline-md text-secondary-fixed mb-2">DR Framework v2</h3>
          <div class="flex flex-wrap gap-2 mb-6">
            {["Terraform", "Azure"].map(tag => (
              <span class="px-2 py-0.5 border border-secondary-fixed text-secondary-fixed font-code-xs text-[10px] uppercase">{tag}</span>
            ))}
          </div>
          <p class="text-on-surface-variant mb-8 flex-grow font-body-md">
            Modular disaster recovery blueprint for mission-critical infrastructure, reducing RTO from hours to minutes via automated state injection.
          </p>
          <button class="w-full py-3 border border-outline-variant text-on-surface-variant font-label-caps text-label-caps hover:border-primary-fixed hover:text-primary-fixed transition-all">
            FETCH_MODULE_SRC
          </button>
        </div>
      </div>
      
      <!-- Project 4: Monitoring Stack -->
      <div class="md:col-span-7 glass-panel group relative overflow-hidden flex flex-col">
        <div class="h-8 bg-surface-container-highest px-4 flex items-center justify-between border-b border-outline-variant">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-error/40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-secondary-fixed/40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-primary-fixed/40"></div>
          </div>
          <span class="font-code-xs text-[10px] text-on-surface-variant/50">dashboard.json</span>
        </div>
        <div class="p-8 flex-grow">
          <div class="w-full h-48 bg-cover bg-center mb-6 border border-outline-variant" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAeaKz0Mfl4hO9zQl8OmuqEwI7ftJIUYqtjuEX4W7FmDogd9IZFdwBNwi9mkHX6y_TUS0v3vbWmOPkOLS-mrDroKB5wzYkxl5z6c-FWKccwG-adbLjaRd1sqLqR6P2mh3Jmb2eoyFd5wxyJ1hnz4wBNguu_fwc3WZq3OzvIYJeiIP882JEI-HHO5uxaZrdsnsnmKL7fUATJ3WvAVu3oeb--shWzc8gE_bGC7HZ_vYvSF9IjifAQh1bf-B7Dd-V8BGZUP9HBaCrzRPA')"></div>
          <h3 class="font-headline-md text-headline-md text-primary-fixed mb-2">Global Observability Stack</h3>
          <p class="text-on-surface-variant mb-6 font-body-md">
            Proprietary Grafana + Prometheus integration for distributed systems tracking. Custom exporters for legacy mainframes.
          </p>
          <div class="flex gap-4">
            <span class="text-primary-fixed font-code-sm flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">visibility</span> 140k/sec Events</span>
            <span class="text-secondary-fixed font-code-sm flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">speed</span> Latency: 2ms</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- STATISTICS SECTION – NOW WITH REAL CONTRIBUTION HEATMAP -->
    <section class="mb-24">
      <h2 class="font-label-caps text-label-caps text-primary-fixed-dim tracking-widest mb-8 flex items-center gap-3">
        <span class="material-symbols-outlined">analytics</span> GITHUB_ANALYTICS
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-1 gap-8">
        <div class="lg:col-span-2 glass-panel p-8">
          <div class="flex justify-between items-center mb-6">
            <span class="font-code-sm text-on-surface-variant">Contribution Matrix (365 Days)</span>
            <!-- The component handles its own legend, but we can add our own label -->
          </div>
          <!-- 
            Replace the mock heatmap with the real component.
            It will render a GitHub-style contribution calendar.
          -->
          <GithubActivity user={GITHUB_USERNAME} theme="dark" />
        </div>
      </div>
    </section>
    
    <!-- CALL TO ACTION -->
    <section class="glass-panel p-16 text-center relative overflow-hidden border-primary-fixed/30 shadow-[0_0_30px_rgba(116,245,255,0.05)]">
      <div class="absolute inset-0 bg-gradient-to-t from-primary-fixed/5 to-transparent"></div>
      <div class="relative z-10">
        <h2 class="font-display text-display text-primary-fixed uppercase mb-4">WANT_TO_COLLABORATE?</h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant mb-10 max-w-xl mx-auto">
  ___________________________________________
        </p>
        <a 
          href="https://github.com/sithilaKonara?tab=repositories" 
          target="_blank" 
          rel="noopener noreferrer"
          class="group px-8 py-4 bg-primary-fixed text-on-primary-fixed font-label-caps text-[16px] font-bold uppercase tracking-widest hover:shadow-[0_0_30px_#74f5ff] transition-all flex items-center justify-center gap-3 mx-auto w-fit"
        >
          [Open GitHub]
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>
    </section>
  </div>
  
  <Footer />
</Layout>

<style>
  .terminal-cursor::after {
    content: '_';
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }
</style>